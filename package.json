{
  "name": "hackathon-offline-mvp",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @hackathon/server --filter @hackathon/extension dev",
    "dev:server": "pnpm --filter @hackathon/server dev",
    "dev:extension": "pnpm --filter @hackathon/extension dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.9.2"
  }
}
