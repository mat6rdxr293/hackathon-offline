var Persons = {
    // Размер ИИН
    IinLength: null,

    // Найти пациента
    find: function (searchCriteria) {
        if (!searchCriteria) {
            showPopupNotification("SearchCriteria is empty", NotificationTypes.danger);
        }

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/person/findPerson',
            data: JSON.stringify(searchCriteria),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },
    //Проверить на предупреждения
    warningCheck: function (model) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        var responce = null;

        $.ajax({
            type: 'POST',
            async: false,
            url: '/person/savePersonWarningCheck',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                responce = result;
            },
        });

        return responce;
    },
    // Сохранить пациента
    save: function (model, successComplete) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/person/savePerson',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;

                if (successComplete) successComplete(result);
            },
        });

        return model;
    },
    // Распарть строку поиска пациента
    parseSearchString: function (searchString) {
        if (!searchString) return;

        var birth = searchString.match(/\b\d{1,2}\.\d{1,2}.\d{4}\b/gm);
        if (birth) {
            searchString = searchString.replace(birth, '').trim();
        } else {
            birth = searchString.match(/[ ]\d{4}/gm);
            searchString = searchString.replace(birth, '').trim();
        }

        // Убираем технические разделители типа " - " перед парсингом
        searchString = searchString.replace(/\s+-\s+/g, ' ').replace(/\s+/g, ' ').trim();

        var search = searchString.split(" ");

        if (search.length < 2) {
            if (!searchString || (!/^\d+$/.test(searchString) && !/^\d{2}-\S+/.test(searchString))) {
                return;
            }
        }

        if (search.length >= 2 && (search[0].length < 2 || search[1].length < 1)) {
            return;
        }

        // Ищем ИИН (12 цифр) среди слов и извлекаем его
        var iinWord = search.find(function(word) { return /^\d{12}$/.test(word); });
        var nameWords = search.filter(function(word) { return !/^\d{12}$/.test(word); });

        // Если нашли ИИН среди слов, используем его
        if (iinWord) {
            return {
                UniqueCode: iinWord,
                LastName: nameWords.length > 0 ? nameWords[0] : null,
                FirstName: nameWords.length > 1 ? nameWords[1] : null,
                SecondName: nameWords.length > 2 ? nameWords[2] : null,
                BirthDate: birth && birth[0].trim().length > 4 ? new Date(+birth[0].split(".")[2], birth[0].split(".")[1] - 1, + birth[0].split(".")[0]).toISOString() : null,
                BirthYear: birth && birth[0].trim().length <= 4 ? birth[0].trim() : null
            };
        }

        return {
            UniqueCode: searchString && (searchString.length === Persons.IinLength && Persons.iinValidation(searchString)) ? searchString : null,
            LastName: searchString && !(searchString.length === Persons.IinLength && Persons.iinValidation(searchString)) ? searchString.split(' ')[0] : null,
            FirstName: searchString && !/^\d+$/.test(searchString) && searchString.split(' ').length > 1 ? searchString.split(' ')[1] : null,
            SecondName: searchString && !/^\d+$/.test(searchString) && searchString.split(' ').length > 2 ? searchString.split(' ')[2] : null,
            BirthDate: birth && birth[0].trim().length > 4 ? new Date(+birth[0].split(".")[2], birth[0].split(".")[1] - 1, + birth[0].split(".")[0]).toISOString() : null,
            BirthYear: birth && birth[0].trim().length <= 4 ? birth[0].trim() : null
        };
    },
    // Проверить использует ли пациент мобильное приложение Damumed
    checkMobileApp: function (personID) {
        if (!personID) {
            showPopupNotification("PersonID is empty", NotificationTypes.danger);
        }

        var result = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/person/checkMobileApp',
            data: JSON.stringify({ id: personID }),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                result = response;
            },
        });

        return result;
    },
    // Валидация ИИН
    iinValidation: function (iin) {
        return /^\d+$/.test(iin);
    },

    // Получить пациента
    get: function (personID) {
        if (!personID) {
            showPopupNotification("PersonID is empty", NotificationTypes.danger);
        }

        var result = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/person/getPerson',
            data: JSON.stringify({ id: personID }),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                result = response;
            },
        });

        return result;
    },
    
    receiveAndSavePerson: function (personMasterDataID) {
        if (!personMasterDataID) {
            showPopupNotification("PersonMasterDataID is empty", NotificationTypes.danger);
            return;
        }

        let request = {
            PersonMasterDataID: personMasterDataID
        }
        
        let result = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/persons/personMasterPatientIndex/receiveAndSavePerson',
            data: JSON.stringify({ request }),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                result = response;
            },
        });
        
        return result;
    },

    // Сопоставить неизвестного
    collapseUnknownPerson: function (request, onSuccess) {
        if (request == null) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }
    
        $.ajax({
            type: 'POST',
            async: false,
            url: '/persons/person/collapseUnknownPerson',
            data: JSON.stringify(request),
            contentType: 'application/json; charset=utf-8',
            success: function () {
                if (typeof onSuccess === 'function') onSuccess();
            },
        });
    },
}

