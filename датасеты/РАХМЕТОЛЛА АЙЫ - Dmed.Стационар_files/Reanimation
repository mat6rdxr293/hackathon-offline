var ResuscitationShifts = {
    // Получить реанимационную смену
    get: function (searchCriteria) {
        if (!searchCriteria) {
            showPopupNotification("SearchCriteria is empty", NotificationTypes.danger);
        }

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/reanimation/GetResuscitationShift',
            data: JSON.stringify(searchCriteria),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },
    // Сохранить реанимационную смену
    save: function (model, successComplete) {
        if (model == null) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/reanimation/saveResuscitationShift',
            data: JSON.stringify(model),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    }
};

