            spinners: false
        });

        if ($('#ntbHealthIndicator').data('kendoNumericTextBox')) {
            $('#ntbHealthIndicator').data('kendoNumericTextBox').focus();
        }

        createNumericControlMaskWrapper(max, decimals);
    }

