var HealthIndicatorBase = function () {
    var deleteControl = function () {
        $('#popupHealthIndicatorEdit').closest('.k-animation-container').remove();
    };

    var deleteControlWindow = function () {
        $('#wndContentWrapper').remove();
    };

    //формируем маску ввода над kendoNumericTextBox для показателей здоровья
    function createNumericControlMaskWrapper(maxValue, decimals) {

        if (decimals > 0) {

            var length = maxValue.toString().length;
            var splitterLenght = 1;
            var maxlength = length + splitterLenght + decimals;
            var beforeSplitterIndex = maxlength - splitterLenght - decimals;

            if (beforeSplitterIndex > 0) {

                $('#ntbHealthIndicator').attr('maxlength', maxlength);

                var input = $("#ntbHealthIndicator").data("kendoNumericTextBox");

                input.element.on("focus", function (e) {
                    if (e.target.value.length == beforeSplitterIndex) {
                        e.target.value += '.0';
                    }
                });

                input.element.on("keyup", function (e) {
                    var backspacekeyCode = 8;
                    if (e.keyCode != backspacekeyCode) {
                        if (e.target.value.length == beforeSplitterIndex && !e.target.value.includes('.')) {
                            e.target.value += '.';
                        }
                    }
                });
            }
        }
    };

    var createNumericControl = function (parent, min, max, format, decimals, savecallback, deletecallback) {
        var value = $(parent).data('value');
        var outputHtml = '\
        <div id="popupHealthIndicatorEdit" style="width:200px;display:none;padding:5px;"> \
            <div class="row"> \
                <div class="col-md-12"> \
                    <input id="ntbHealthIndicator" name="ntbHealthIndicator" type="number" style="width:100%;" \
                        min="' + min + '" max="' + max + '" /> \
                </div> \
            </div> \
        </div>';

        $(parent).append(outputHtml);

        $('#ntbHealthIndicator').kendoNumericTextBox({
            format: format || 'n0',
            decimals: decimals || 0,
            value: value && value.toString().replace(',', '.') || null,
            spinners: false,
            change: function (e) {
                var _value = e.sender.value();
                if (_value !== null && _value !== undefined) {
                    savecallback(parent, _value);
                } else {
                    deletecallback(parent);
                }
            }
        });

        $('#popupHealthIndicatorEdit').kendoPopup({
            anchor: $(parent)
        });
        $('#popupHealthIndicatorEdit').data('kendoPopup').open();

        if ($('#ntbHealthIndicator').data('kendoNumericTextBox')) {
            $('#ntbHealthIndicator').data('kendoNumericTextBox').focus();
        }

        createNumericControlMaskWrapper(max, decimals);
    };

    var createNumericControlForWindow = function (parent, prevValue, min, max, format, decimals) {
