function cannotEditMedicalHistoryDisableBtnAndLinkObserver(resource) {
    const observer = new MutationObserver(() => {
        disableElements(".isBtnDisabledWithTitle", button => {
            button.disabled = true;
            button.title = resource || "Modifying a closed medical record is prohibited.";
            button.removeAttribute("onclick");
        });

        disableElements(".isLinkDisabledWithTitle", link => {
            link.removeAttribute("style");
            link.classList.add("disabled-label");
            link.title = resource || "Modifying a closed medical record is prohibited.";
            link.removeAttribute("onclick");
            link.removeAttribute("href");
        });

        disableElements(".isLabelDisabledWithTitle", label => {
            label.classList.add("disabled-label");
            label.title = resource || "Modifying a closed medical record is prohibited.";
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
}

function disableElements(selector, action) {
    document.querySelectorAll(selector).forEach(element => action(element));
};
