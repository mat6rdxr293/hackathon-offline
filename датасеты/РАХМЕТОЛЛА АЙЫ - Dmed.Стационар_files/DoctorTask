var DoctorTasks = {
    // Получить список задач
    list: function (searchCriteria) {
        if (!searchCriteria) {
            showPopupNotification("SearchCriteria is empty", NotificationTypes.danger);
        }

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/doctorTask/getDoctorTasks',
            data: JSON.stringify({ listQueryModel: searchCriteria }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },

    // Получить задачу
    get: function (id) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/doctorTask/getDoctorTask',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },

    // Сохранить задачу
    save: function (model, successComplete) {
        if (model == null) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/doctorTask/saveDoctorTask',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    },

    // Выполнить задачу
    execute: function (model, successComplete) {
        if (model == null) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/doctorTask/executeDoctorTask',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    },
};
