var Dictionaries = {
    // Получить значения справочника
    list: function (dictionaryName, searchCriteria) {
        var path = DictionaryUrls.get(dictionaryName);
        if (!path) return [];

        var listModel = [];
        $.ajax({
            type: 'POST',
            async: false,
            url: path,
            data: JSON.stringify({ listQueryModel: searchCriteria }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                listModel = result;
            },
        });

        return listModel;
    },

    // Получить значение справочника
    get: function (dictionaryName, id) {
        var path = DictionaryItemUrls.get(dictionaryName);
        if (!path) return [];

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: path,
            data: JSON.stringify({ id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },

    // Найти значение справочника
    find: function (dictionaryName, searchCriteria) {
        var path = DictionaryFindItemUrls.get(dictionaryName);
        if (!path) return [];

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: path,
            data: JSON.stringify(searchCriteria),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    }
}

