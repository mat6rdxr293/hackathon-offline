            if (clipboardData.files && clipboardData.files.length > 0) {
                file = clipboardData.files[0];
                handleImagePaste(file);
            }
            pastedData = clipboardData.getData('text/html');

            if (pastedData) {
                const tempElement = event.target.ownerDocument.createElement('div');
                tempElement.innerHTML = pastedData;

                // Удалить все стили из HTML-контента
                removeAllStyles(tempElement);
                insertTextAtCursor(tempElement.innerHTML, event.target);
            } else {
                pastedData = clipboardData.getData('text/plain');
                insertTextAtCursor(pastedData, event.target);
            }


            function removeAllStyles(element) {
                // Удаляем атрибуты style у всех элементов
                const elementsWithStyleOrClass = element.querySelectorAll('[style], [class], [lang]');
                elementsWithStyleOrClass.forEach(el => {
                    if (el.hasAttribute('style')) {
                        const style = el.style;
                        const color = style.color; // Сохраняем цвет

                        el.removeAttribute('style'); // Удаляем все стили

                        if (color) {
                            el.style.color = color; // Восстанавливаем цвет
                        }
                    }
                    
                    el.removeAttribute('class');
                    el.removeAttribute('lang');
                });

                // Удаляем все элементы <style> и <link> и <meta>
                const styles = element.querySelectorAll('style, link, meta');
                styles.forEach(style => style.remove());

                // Рекурсивная функция для удаления комментариев
                function removeComments(node) {
                    for (let i = node.childNodes.length - 1; i >= 0; i--) {
                        const child = node.childNodes[i];
                        if (child.nodeType === Node.COMMENT_NODE) {
                            node.removeChild(child); // Удалить комментарий
                        } else if (child.nodeType === Node.ELEMENT_NODE || child.nodeType === Node.DOCUMENT_FRAGMENT_NODE) {
                            removeComments(child); // Рекурсивно пройтись по дочерним элементам
                        }
                    }
                }

                removeComments(element);
            }
        function insertTextAtCursor(html, element) {
            // Если элемент - это textarea или input, вставляем текст в него
            if (element.tagName === 'TEXTAREA' || element.tagName === 'INPUT') {
                // Получаем текущую позицию курсора
                var startPos = element.selectionStart;
                var endPos = element.selectionEnd;

                // Вставляем текст на место курсора
                element.value = element.value.substring(0, startPos) + html + element.value.substring(endPos);
                element.innerHTML = element.value.substring(0, startPos) + html + element.value.substring(endPos);

                // Перемещаем курсор после вставленного текста
                element.selectionStart = element.selectionEnd = startPos + html.length;
            } else {
                var ownerdocument = element.ownerDocument;
                // Получаем текущее выделение (selection) и его диапазон (range)
                const sel = ownerdocument.getSelection();
                if (sel.rangeCount > 0) {
                    const range = sel.getRangeAt(0);

                    // Удаляем содержимое в диапазоне и вставляем новое
                    range.deleteContents();

                    // Создаем временный контейнер для HTML-контента
                    const tempDiv = ownerdocument.createElement("div");
                    tempDiv.innerHTML = html;

                    // Вставляем каждый дочерний элемент временного контейнера
                    let fragment = ownerdocument.createDocumentFragment();
                    while (tempDiv.firstChild) {
                        fragment.appendChild(tempDiv.firstChild);
                    }

                    sel.getRangeAt(0).insertNode(fragment);
                    sel.collapseToEnd();
                }
            }
        }

            function handleImagePaste(file) {
