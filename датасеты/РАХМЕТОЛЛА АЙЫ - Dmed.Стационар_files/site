function getAge(birth) {

    var today = new Date();
    var nowyear = today.getFullYear();
    var nowmonth = today.getMonth();
    var nowday = today.getDate();

    var res = birth.split(".");

    var birthyear = parseInt(res[2]);
    var birthmonth = parseInt(res[1]);
    var birthday = parseInt(res[0]);

    var age = nowyear - birthyear;
    var age_month = nowmonth - birthmonth;
    var age_day = nowday - birthday;

    if (age_month < 0 || (age_month == 0 && age_day < 0)) {
        age = parseInt(age) - 1;
    }

    return age;
}

//Высчитывает количество лет на текущую дату, либо на заданную
//birthDate - Дата рождения
//date - дата к расчету (необязательный параметр)
function getCalculatedAge(birthDate, date) {
    if (!birthDate) {
        throw 'Произошла ошибка, дата рождения не указана \n birthDate - ' + birthDate + "!";
    }

    date = !date ? new Date() : date;

    if (typeof (birthDate) != "object" || typeof (date) != "object") {
        throw "Произошла ошибка, переданные параметры не соответствуют типу \"Date\"!";
    }

    if (date < birthDate) {
        console.log("Дата постановки меньше чем дата рождения: \n\t Дата рождения - " + birthDate + "\n\t Дата постановки - " + date + "\n\t Результат расчета возраста равен 0");
        return 0;
    }

    var dateNumberWithoutYear = date.getMonth() * 100 + date.getDate();
    var birthDateNumberWithoutYear = birthDate.getMonth() * 100 + birthDate.getDate();

    //Возраст = текущий год - год рождения
    var age = date.getFullYear() - birthDate.getFullYear();

    //Если ДР в этом году ещё предстоит, то вычитаем из age один год
    if (birthDateNumberWithoutYear > dateNumberWithoutYear) {
        age = age - 1;
    }

    return age;
}

