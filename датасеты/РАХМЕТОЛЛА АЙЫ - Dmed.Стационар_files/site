function openAjaxDialog(init) {
    $.ajax({
        url: init.url || '',
        type: init.type || 'POST',
        data: JSON.stringify(init.data),
        contentType: 'application/json; charset=utf-8',
        success: function (view) {
            if (init.success && typeof (init.success) == "function")
                init.success(view);

            $(init.selector + ' .modal-body').html(view);

            if (init.title)
                $(init.selector + ' .modal-title').html(init.title);

            $(init.selector).draggable({
                handle: ".modal-header"
            });

            if (init.htmlAttributes) {
                for (var attr in init.htmlAttributes) {
                    if (!init.htmlAttributes.hasOwnProperty(attr)) continue;

                    $(init.selector + ' .modal-body').attr(attr, init.htmlAttributes[attr]);
                }
            }

            $(init.selector).modal('show');

            $(init.selector).on('hidden.bs.modal', function (e) {
                $(init.selector + ' .modal-body').html(null);
                if (init.onHidden)
                    init.onHidden();
            });
        },
        error: function (ex) {
            if (init.error && typeof (init.error) == "function")
                init.error(ex);

            systemErrorNotification(ex);
        },
        complete: function () {
            if (init.complete && typeof (init.complete) == "function")
                init.complete();
        }
    });
}


