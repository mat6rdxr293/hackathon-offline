function getBrowserInfo() {
    var ua = navigator.userAgent,
        tem,
        match = ua.match(/(opera|chrome|safari|firefox|msie|trident(?=\/))\/?\s*(\d+)/i) || [];

    if (/trident/i.test(match[1])) {
        tem = /\brv[ :]+(\d+)/g.exec(ua) || [];
        return { name: 'IE', version: tem[1] || '' };
    }

    if (match[1] === 'Chrome') {
        tem = ua.match(/\bOPR|Edge\/(\d+)/)
