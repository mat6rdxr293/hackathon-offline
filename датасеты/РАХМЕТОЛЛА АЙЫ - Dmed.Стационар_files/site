var NotificationTypes = {
    info: "info",
    error: "error",
    danger: "danger",
    success: "success",
    warning: "warning"
}

function showPopupNotification(message, notificationType) {
    var notification = $("#popupNotification").data("kendoNotification");

    if (!notificationType)
        notificationType = NotificationTypes.info;

    var formatedmessage = '';
    var messages = message.split('<br />');
    for (var i = 0; i < messages.length; i++) {
        for (var j = 0; j < messages[i].length; j++) {
            if (j != 0 && j % 200 == 0) {
                formatedmessage += messages[i][j] + '<br />';
            } else {
                formatedmessage += messages[i][j];
            }
        }
        if (i + 1 < messages.length) {
            formatedmessage += '<br />';
        }
    }

    notification.show(formatedmessage, notificationType);
}

