Array.prototype.uniqueByID = function () {
    var uniqueArray = [];
    for (let i = 0; i < this.length; i++) {
        var uniqueValue = uniqueArray.find(o => o.ID == this[i].ID);
        if (!uniqueValue) {
            uniqueArray.push(this[i]);
        }
    }
    return uniqueArray;
};

