function openDialogEvent(url, dataObj, dlgForm, funcSuccess) {
    var isDialogOpened = dlgForm.attr('isDialogOpened');

    dlgForm.dialog('open');

    if (isDialogOpened == undefined) {
        dlgForm.attr('isDialogOpened', false);
        isDialogOpened = false;
    }

    if (isDialogOpened == 'true') {
        isDialogOpened = true;
    }

    if (isDialogOpened == 'false') {
        isDialogOpened = false;
    }

    if (isDialogOpened) {
        return;
    }
    else {
        isDialogOpened = true;
        dlgForm.attr('isDialogOpened', true);
    }

    if (url && url.length > 0) {
        performAjaxRequest(url, dataObj, function(data) {
            dlgForm.html(data);

            if (funcSuccess) {
                funcSuccess(data);
            }
        });
    }
}

