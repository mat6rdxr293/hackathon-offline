function selectedDateValidate(value, element, params) {
    if (!value) { return true; }
    
    if (typeof (value) != 'string' || /^\d+$/.test(value) || /^[a-zA-Z]+$/.test(value)) { return false; }

    var isDateTime = false;
    var date = '';
    var time = '';
    if (value.includes(' ')) {
        isDateTime = true;
        var dateTime = value.split(' ');
        date = dateTime[0];
        time = dateTime[1];
    } else {
        date = value;
    }
    if (!date) { return false; }

    var dot = '.';
    var dash = '-';
    var slash = '/';
    var separators = [dot, dash, slash];
    var separator = ''; 
    var dd = '';
    var MM = '';
    var yyyy = '';
    for (var i = 0; i < separators.length; i++) {
        if (date.includes(separators[i])) {
            separator = separators[i];
            var  ddMMyyyy = date.split(separator);
            dd = ddMMyyyy[0];
            MM = ddMMyyyy[1];
            yyyy = ddMMyyyy[2];
            break;
        }
    }
    if (!separator || !dd || !MM || !yyyy) { return false }

    var dayInt = parseInt(dd);
    var monthInt = parseInt(MM);
    var yearInt = parseInt(yyyy);
    if (typeof dayInt != 'number' || typeof monthInt != 'number' || typeof yearInt != 'number') { return false; }

    var february = yearInt % 4 == 0 ? 29 : 28;
    var months = [31, february, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
    var isDayInvalid = dd > months[monthInt - 1]; 
    if (isDayInvalid) { return false; }

    var newDate = new Date(yearInt, monthInt - 1, dayInt);
    var isNaNDate = isNaN(newDate.getTime());
    if (isNaNDate) { return false; }

    if (isDateTime) {
        if (!time) { return false; }

        var isValidTime = /^([0-1]?[0-9]|2[0-3]):([0-5][0-9])(:[0-5][0-9])?$/.test(time);
        return isValidTime;
    }

    return true;
}

