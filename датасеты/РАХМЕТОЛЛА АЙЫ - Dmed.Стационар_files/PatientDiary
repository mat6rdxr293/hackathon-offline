var PatientDiaries = {
    //Удалить дневниковую запись
    delete: function (id, successComplete) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            url: '/patientDiary/deleteDiary',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                if (successComplete) successComplete();
            },
        });
    },
    //Отменить удаление дневниковой записи
    undoDelete: function (id, successComplete) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            url: '/patientDiary/undoDeleteDiary',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                if (successComplete) successComplete();
            },
        });
    },
    // Сохранить дневниковую запись
    save: function (model, successComplete) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/patientDiary/saveDiary',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    },
    // Получить последнюю дневниковую запись
    getLastDiary: function (searchCriteria) {
        if (!searchCriteria) {
            showPopupNotification("SearchCriteria is empty", NotificationTypes.danger);
        }

        var model = null;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/patientDiary/getLastDiary',
            data: JSON.stringify(searchCriteria),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
            },
        });

        return model;
    },
};;
