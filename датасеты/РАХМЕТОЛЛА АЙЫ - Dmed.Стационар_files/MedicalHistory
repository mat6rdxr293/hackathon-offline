    // Расчитать количество проведенных койко дней
    getBedDaysCount: function (inPatientHelpTypeID, hospitalDate, outDateTime) {
        var bedDays = 0;
        var currentOutDate = new Date(outDateTime);

        if (currentOutDate == null) return 0;
        if (inPatientHelpTypeID == 1) {
            bedDays = Math.floor((currentOutDate.setHours(0, 0, 0) - hospitalDate.setHours(0, 0, 0)) / (1000 * 24 * 60 * 60));
            return bedDays <= 0 ? 1 : bedDays;
        }

        while (new Date(hospitalDate.toDateString()) <= new Date(currentOutDate.toDateString())) {
            if (hospitalDate.getDay() != 6 && hospitalDate.getDay() != 0) {
                bedDays++;
            }
            hospitalDate.setDate(hospitalDate.getDate() + 1)
        }
        return bedDays;
    },
