// Типы документов
var documentEnumNames = {
    get: function (documentType, documentKind = 10) {
        switch (documentType) {
            case 10: return 'HealthCertificate027';
            case 20: return 'HealthCertificate036';
            case 30: return 'HealthCertificate037';
            case 40: return documentKind == 10 ? 'HealthCertificate038' : 'HealthCertificate038PatientCare';
            case 50: return 'HealthCertificate079';
            case 60: return 'HealthCertificate031';
            case 70: return 'HealthCertificateNew031';
            case 80: return 'HealthCertificate033';
            case 90: return 'HealthCertificate031United';
            default: return '';
        }
    }
};

