var PatientContactNotifications = {
    // Сохранить уведомление
    save: function (model, successComplete) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/PatientContactNotification/savePatientContactNotification',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    },
    // Отправить уведомление
    send: function (id, successComplete) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/PatientContactNotification/sendPatientContactNotification',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                if (successComplete) successComplete(result);
            },
        });
    },
    // Удалить уведомление
    delete: function (id, successComplete) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/PatientContactNotification/deletePatientContactNotification',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                if (successComplete) successComplete(result);
            },
        });
    },
}

