                var connection = $.grep(connections, function (c) { return c.id == roomId; });
                if (connection.length > 0) return connection[0];

                return undefined;
            };

            var init = function (members) {
                var conference = undefined;

                $.ajax({
                    url: settings.url + "/api/Messenger/CreateConference",
                    data: JSON.stringify({
                        Members: members,
                        Token: settings.context.token
                    }),
                    xhrFields: {
                        withCredentials: true
