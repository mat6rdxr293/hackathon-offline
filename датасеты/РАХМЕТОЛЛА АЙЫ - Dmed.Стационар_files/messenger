                var connection = get(roomId);

                Signaling.invoke({
                    roomId: roomId,
                    messageType: messageTypes.cancel,
                    message: 'cancel'
                }).then(function () {
                    connection.peerConnection.close();
                    connections.splice(connections.map(function (c) { return c.id; }).indexOf(connection.id), 1);

                    if (!isActive()) Signaling.stop();
                });
            };

            var isActive = function () {
                var activeConnections = $.grep(connections, function (connection) {
                    return connection.state === connectionStates.closed;
                });

                return activeConnections.length > 0;
            };

            var stopActives = function () {
                connections.map(function (connection) {
                    Caller.stop(connection.id);
                });
            };

            return {
