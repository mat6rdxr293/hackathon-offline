                        OfferToReceiveVideo: true
                    }
                }).then(function (offer) {
                    return connection.peerConnection.setLocalDescription(offer);
                }).then(function () {
                    Signaling.invoke({
                        roomId: roomId,
                        messageType: messageTypes.call,
                        message: JSON.stringify(connection.peerConnection.localDescription)
                    });

                    connection.state = connectionStates.open;
                }).catch(function (error) {
