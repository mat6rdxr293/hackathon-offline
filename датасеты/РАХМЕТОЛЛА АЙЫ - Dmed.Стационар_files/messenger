                    stream.getTracks().forEach(function (track) {
                        return connection.peerConnection.addTrack(track, stream);
                    });

                    Connection.answer(roomId, chatModel);

                    $('#' + _self.prop('id') + '_stop').unbind("click");

                    $('#' + _self.prop('id') + '_stop').click(function () {
                        stop(_roomId);
                    });
                }).catch(function (e) {
                    stop(roomId);

