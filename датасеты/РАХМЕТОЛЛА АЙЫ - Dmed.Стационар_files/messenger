                });;
            };

            var stop = function (roomId) {
                $('#' + _self.prop('id') + '_video').addClass('hidden');
                if (localVideo) {
                    localVideo.getTracks().forEach(track => track.stop());
                    localVideo = undefined;
                }
                document.getElementById('localVideo').srcObject = undefined;
                document.getElementById('remoteVideo').srcObject = undefined;

                Connection.destroy(roomId);

                var endDate = new Date();
                startDate = startDate || new Date();

                var diff = endDate.getTime() - startDate.getTime();

                var days = Math.floor(diff / (1000 * 60 * 60 * 24));
                var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((diff % (1000 * 60)) / 1000);

                Display.show(settings.messages.CallCompleted + " " + hours + " " + settings.messages.Hours + " " + minutes + " " + settings.messages.Minutes + " " + seconds + " " + settings.messages.Seconds);

                startDate = undefined;

                settings.events.caller.stop();
