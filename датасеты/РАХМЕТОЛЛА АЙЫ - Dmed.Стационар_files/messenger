                    traditional: true,
                    async: false,
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    success: function (result) {
                        conference = result;
                    },
                    error: function (ex) {
                        settings.events.conference.error(ex);
                    }
                });

                if (!conference) return undefined;

                var connection = get(conference.Room.ID);
                if (connection) return connection;
                
                $.ajax({
                    type: 'POST',
                    url: conference.Url + '/api/setting/turnServerData',
                    headers: {
                        Authorization: 'Bearer ' + conference.Token
                    },
                    async: false,
                    contentType: 'application/json; charset=utf-8',
                    success: function (result) {
                        let base64 = CryptoJS.enc.Utf8.parse(cryptoJSextension.key(conference.TurnToken))
                        let decrypt = CryptoJS.TripleDES.decrypt(result, base64, {
                                mode: CryptoJS.mode.ECB,
                                padding: CryptoJS.pad.Pkcs7
                            }
                        );
                        
                        let parseData = decrypt.toString(CryptoJS.enc.Utf8);
                        turnServer = JSON.parse(parseData);
                    },
                    error: function (ex) {
                        settings.events.connection.error(ex);
                    }
                });

                var iceServers = [{
                    urls: googleStunUrls
                }];

                if (turnServer) {
                    iceServers.push({
                        urls: 'stun:' + turnServer.Url,
                        username: turnServer.Username,
                        credential: turnServer.Password
                    });

                    iceServers.push({
                        urls: 'turn:' + turnServer.Url + '?transport=udp',
                        username: turnServer.Username,
                        credential: turnServer.Password
                    });

                    iceServers.push({
                        urls: 'turn:' + turnServer.Url + '?transport=tcp',
                        username: turnServer.Username,
                        credential: turnServer.Password
                    });
                }

                connection = {
                    id: conference.Room.ID,
                    token: conference.Token,
                    name: conference.Room.Name,
                    url: conference.Url,
                    peerConnection: new window.RTCPeerConnection({
                        iceServers: iceServers
                    }),
                    state: connectionStates.closed
                };

                connection.peerConnection.onicecandidate = function (event) {
                    if (!event.candidate) return;

                    Signaling.invoke({
                        roomId: conference.Room.ID,
                        messageType: messageTypes.candidate,
                        message: JSON.stringify(event.candidate)
                    });
                };

                connections.push(connection);

                return connection;
