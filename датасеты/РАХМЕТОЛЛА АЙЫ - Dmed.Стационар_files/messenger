                    Connection.offer(roomId);

                    $('#' + _self.prop('id') + '_stop').unbind("click");

                    $('#' + _self.prop('id') + '_stop').click(function () {
                        stop(_roomId);
                    });
                }).catch(function (e) {
                    stop(roomId);

                    var message = settings.messages[e.name] ? settings.messages[e.name] : e.name;
                    Display.show(settings.messages.CallCompleted + ". " + message);
