    // Получить назначения, где медикаменты или МНН схожи полностью по составу с назначаемыми
    getMedAssignmentsWithSameDrugsAndSubstances: function (model, successComplete, errorFunction) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
            return;
        }

        if ((!model.MedAssignmentDrugs || !model.MedAssignmentDrugs.length) && (!model.MedAssignmentSubstances || !model.MedAssignmentSubstances.length))
            return [];

        var substances = [];

        if (model.MedAssignmentSubstances && model.MedAssignmentSubstances.length > 0) {
            model.MedAssignmentSubstances.forEach(s => {
                substances.push({ 'SubstanceIDs': s.Substances.map(x => x.ID) });
            });
        }

        if (model.MedAssignmentDrugs && model.MedAssignmentDrugs.length > 0) {
            var uniqueDrugAssignmentIDs = [...new Set(model.MedAssignmentDrugs.map(x => x.DrugAssignmentID))]

            uniqueDrugAssignmentIDs.forEach(d => {
                substances.push({ 'SubstanceIDs': Dictionaries.get("DrugAssignment", d).Substances.map(x => x.ID) });
            });
        }

        var res;
        $.ajax({
            type: 'POST',
            async: false,
            url: '/medicalAssignment/GetMedAssignmentsWithSameDrugsAndSubstances',
            data: JSON.stringify({
                PatientAdmissionRegisterID: model.PatientAdmissionRegisterID,
                Substances: substances,
                BeginAssignmentDate: model.BeginAssignmentDate,
                EndAssignmentDate: model.EndAssignmentDate
            }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                res = result;
                if (successComplete) successComplete(result);
            },
            error: function () {
                if (errorFunction) errorFunction();
            }
        });

        return res;
    },

