var PatientTransfers = {
    // Сохранить перемещение пациента
    save: function (model, successComplete) {
        if (!model) {
            showPopupNotification("Model is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/patientTransfer/savePatientTransfer',
            data: JSON.stringify({ model }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                model = result;
                if (successComplete) successComplete(result);
            },
        });

        return model;
    },

    // Удалить перемещение пациента
    delete: function (id, successComplete, errorComplete) {
        if (!id) {
            showPopupNotification("Id is empty", NotificationTypes.danger);
        }

        $.ajax({
            type: 'POST',
            async: false,
            url: '/patientTransfer/deletePatientTransfer',
            data: JSON.stringify({ id: id }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                if (successComplete) successComplete(result);
            },
            error: function (event) {
                if (errorComplete) errorComplete(event && event.responseText);
            }
        });
    },

    //Установить цвет отображения палаты
    setColor: function (bedCount, BusyBedCount) {
        if (bedCount === BusyBedCount) return 'panel-warning';
        if (bedCount > BusyBedCount) return 'panel-success';
        if (bedCount < BusyBedCount) return 'panel-danger';
    }
};;
