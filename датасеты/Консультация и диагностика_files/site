function _openWithPost(url, data) {
    const $form = $('<form>', {
        action: url,
        method: 'POST',
        target: '_blank'
    });

    $.each(data, function (key, value) {
        $('<input>').attr({
            type: 'hidden',
            name: key,
            value: value
        }).appendTo($form);
    });

    $form.appendTo('body').submit().remove();
}
