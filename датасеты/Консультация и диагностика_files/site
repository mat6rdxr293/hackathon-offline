function phoneMask(str) {
    if (
        (str.length > 11 && str.substring(0, 2) === '+7')
            || (str.length > 10 && str.substring(0, 1) === '8')
            || (str.length > 10 && str.substring(0, 2) !== '+7')
    ) {
        if (str.substring(0, 1) === '8')
            str = str.substring(1, 50);
        else if (str.substring(0, 2) === '+7')
            str = str.substring(2, 50);
        var num = str.substring(0, 50).replace(/\D/g, '');

        return '+7' + '(' + num.substring(0, 3) + ')' + num.substring(3, 6) + '-' + num.substring(6, 8) + '-' + num.substring(8, 10);
    } else {

        return str;
    }
}

function phoneKzValidation(phoneNumber, element) {
    phoneNumber = phoneNumber.replace(/\s+/g, "");
    return this.optional(element) || phoneNumber.length > 9 &&
        phoneNumber.match(/^\+?7\-?\(?[0-9]{3}\)?\-?[0-9]{3}\-?[0-9]{2}\-?[0-9]{2}$/);
}

function OnKeyUpMobilePhone(e) {
    if (e.keyCode != 8 && e.keyCode != 46) {
        e.currentTarget.value = phoneMask(e.currentTarget.value);
    }
};

