            resizable: false,
            modal: true,
            width: 520,
            animation: false
        });
    }

    // Очищаем предыдущие обработчики событий перед установкой новых
    kendoWindow.data("kendoWindow").unbind("deactivate");

    kendoWindow
        .data("kendoWindow")
        .content($("<div />").html(attentionConfirmation({ message: message })))
        .center().open();

    kendoWindow.find(".attention-confirm, .attention-cancel").on("click", function () {
        if ($(this).hasClass("attention-confirm")) {
            kendoWindow.data("kendoWindow").bind("deactivate", function () {
                attentionConfirm(param);
            });
        }
        kendoWindow.data("kendoWindow").close();
    });
}

