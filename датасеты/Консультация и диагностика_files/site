            data: JSON.stringify({ lang: lang }),
            contentType: 'application/json; charset=utf-8',
            success: function (result) {
                localStorage.setItem('lang', result);
                location.reload();                
            },
        });
    };

    var culture = function () {
        return localStorage.getItem('lang') || 'ru';
    };

    return {
        changeCulture: changeCulture,
        culture: culture,
    };
}();

var upperkey = function (e) {
    var selectionEnd = $(e.target).get(0).selectionEnd;
    var value = $(e.target).val();
    if (e.which != 13 && e.which != 46 && e.which != 8 && e.which != 17 && (e.which < 96 || e.which > 105) && value) {
        value = value.toUpperCase();
        $(e.target).val(value);
        $(e.target).get(0).setSelectionRange(selectionEnd, selectionEnd);
    }
};

var scrollLink = function (clickedLink, navHeight) {
    var elementClass = clickedLink.attr('href').replace('#', '.');
    var scrollPosition = 0;
    if (elementClass != '.top-content') {
        elementClass += '-container';
        scrollPosition = $(elementClass).offset().top - navHeight;
    }
    if ($(window).scrollTop() != scrollPosition) {
        $('html, body').stop().animate({ scrollTop: scrollPosition }, 1000);
    }
};

