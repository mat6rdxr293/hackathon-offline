/**
 * объект для работы с капчей от google
 * капча одна для разных форм
 * вызывается, если требуется, перед обращением к серверу, передавая функцию обращения как параметр
 */
var Captcha = (function () {
    var widget,
        dialogId,
        captchaId,
        publicKey,
        captchaResponse,
        showCallback = function (response) { };

    var captchaSuccessCallback = function (response) {
        showCallback(response);
    }

    return {
        /**
        * создает капчу в разметке
        * @param {} reCaptchaPublicKey - публичный ключ для reCAPTCHA         
        * @returns {} 
        */
        create: function (reCaptchaPublicKey) {
            publicKey = reCaptchaPublicKey;
            captchaId = 'recapcha';
            dialogId = 'recaptcha-dialog';

            $('#' + dialogId).kendoWindow({
                width: 335,
                title: 'Докажите, что вы не робот',
                visible: false,
                draggable: false,
                modal: true,
            });
        },
        /**
        * показывает капчу в новом окне
        * @param {} callback - функция вызывается после удачного подтверждения проверки
        * @returns {} 
        */
        show: function (resultFunc) {
            showCallback = resultFunc;

            $('#recaptcha-dialog').data('kendoWindow').center().open();

            if (widget >= 0) {
                grecaptcha.reset(widget);
                return;
            }

            widget = grecaptcha.render(captchaId, {
                sitekey: publicKey,
                callback: function (response) {
                    captchaResponse = response;

                    grecaptcha.reset(widget);
                    $('#recaptcha-dialog').data('kendoWindow').close();

                    captchaSuccessCallback(response);
                }
            });
        },
        showPromise: function () {
            return new Promise((resolve, reject) => {
                $('#recaptcha-dialog').getKendoWindow().center().open();

                if (widget >= 0) {
                    grecaptcha.reset(widget);
                    resolve();
                }

                widget = grecaptcha.render(captchaId, {
                    sitekey: publicKey,
                    callback: function (response) {
                        grecaptcha.reset(widget);
                        $('#recaptcha-dialog').data('kendoWindow').close();
                        resolve(response);                        
                    }
                }); 
            });            
        },
        /**
        * возвращает результат проверки капчи
        * @returns {} 
        */
        getResponse: function () {
            if (!captchaResponse) return null;

            var response = captchaResponse.slice(0);
            captchaResponse = null;

            return response;
        }
    };
}());;
