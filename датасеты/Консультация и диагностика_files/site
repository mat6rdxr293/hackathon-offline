var showNotification = function (message, notificationType, time) {
    
    if (!notificationType)
        notificationType = NotificationTypes.info;

    if (notificationType == NotificationTypes.error) notificationType = 'danger';

    var uid = guid();
    
    if (!time)
        time = 15000;

    $('#notification-dialog').append('\
<div id="' + uid + '" class="alert alert-' + notificationType + ' alert-dismissible" role="alert"> \
    <button type="button" class="close" data-dismiss="alert" aria-label="Close"> \
        <span aria-hidden="true">&times;</span> \
    </button> \
    ' + message + ' \
</div> \
');

    var timeout = setTimeout(function () {
        $('#notification-dialog #' + uid).fadeOut('slow');
    }, time);

    $('#notification-dialog #' + uid).mousemove(function (e) {
        clearTimeout(timeout);
    });

    $('#notification-dialog #' + uid).mouseleave(function (e) {
        timeout = setTimeout(function () {
            $('#notification-dialog #' + uid).fadeOut('slow');
        }, 7000);
    });
};


